{
  "expo": {
    "name": "Whack-a-Mole",
    "slug": "whack-a-mole",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "whackamole",
    "splash": {
      "image": "./assets/images/orig.png",
      "resizeMode": "cover",
      "backgroundColor": "#3E2723"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#3E2723"
      },
      "package": "com.marl.whackamole",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d086c313-fa95-4145-9883-6e79f8424c2d"
      }
    }
  }
}
